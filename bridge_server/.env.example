# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Public hostname Twilio uses to reach us (set after ngrok/cloudflared boots).
# Used to build the wss:// URL in the TwiML response. No scheme, no path.
# Example: PUBLIC_HOST=abc123.ngrok.app
PUBLIC_HOST=

# Hermes (OpenAI-compatible)
HERMES_BASE_URL=http://localhost:8642/v1
HERMES_API_KEY=voiceagent-secret-key-2024
HERMES_MODEL=hermes-agent

# Groq Whisper (STT)
GROQ_API_KEY=
GROQ_STT_MODEL=whisper-large-v3-turbo

# Edge TTS
EDGE_TTS_VOICE=zh-CN-XiaoxiaoNeural

# Twilio (optional — only needed for signature validation / outbound calls)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
