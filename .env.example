# =============================================================================
# VoiceAgent 环境变量配置
# 复制为 .env 并填入你的凭证
# =============================================================================

# ── 服务器 ──────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# ── Hermes (LLM 对话引擎) ──────────────────────────────────────────────────
HERMES_BASE_URL=http://localhost:8642/v1
HERMES_API_KEY=voiceagent-secret-key-2024
HERMES_MODEL=hermes-agent

# ── 阿里云 NLS (语音识别 + 语音合成) ───────────────────────────────────────
ALIYUN_AK_ID=
ALIYUN_AK_SECRET=
ALIYUN_NLS_APPKEY=
ALIYUN_NLS_REGION=cn-shanghai
ALIYUN_NLS_TTS_VOICE=zhixiaoxia

# ── 企业微信群机器人 Webhook (访客通知推送) ─────────────────────────────────
WECHAT_WEBHOOK_URL=

# ── 企业微信 AI Bot (可选，用于查询功能) ───────────────────────────────────
# 在企业微信管理后台创建 AI Bot 后获取
# WECOM_BOT_ID=
# WECOM_SECRET=

# ── DeepSeek API (Hermes 底层模型 建议deepseek-chat模型) ─────────────────────────────────────────
# 在 Hermes 的 ~/.hermes/profiles/voiceagent/config.yaml 中配置
# DEEPSEEK_API_KEY=
